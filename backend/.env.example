# --- Extraction (OpenRouter, OpenAI-compatible) ---
OPENROUTER_API_KEY=sk-or-...
# Optional overrides:
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
OPENROUTER_REFERER=https://your-frontend.vercel.app
# Model that phrases the plain-English AI explanations (cheap/fast is fine):
OPENROUTER_EXPLAIN_MODEL=anthropic/claude-haiku-4.5

# --- Admin dashboard (/admin) ---
ADMIN_EMAIL=aiplanner04@gmail.com
ADMIN_PASSCODE=change-me-to-a-secret

# --- Database (Render Postgres). Leave unset to use local SQLite in dev. ---
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- CORS: comma-separated allowed frontend origins (any *.vercel.app is allowed automatically) ---
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
